{
    "scopeName": "source.senior",
    "name": "Senior LSP",
    "patterns": [
        {
            "name": "comment.line.senior",
            "match": "@.*$"
        },
        {
            "name": "comment.block.senior",
            "begin": "/\\*",
            "end": "\\*/"
        },
        {
            "name": "keyword.control.senior",
            "match": "(?i)\\b(se|senao|enquanto|para|fim|inicio|funcao|retorne|mensagem|cancelar|continue|vapara|regra)\\b"
        },
        {
            "name": "storage.type.senior",
            "match": "(?i)\\b(definir|numero|alfa|data|tabela|cursor|grid|fimse|fimpara|fimenquanto)\\b"
        },
        {
            "name": "constant.language.senior",
            "match": "(?i)\\b(retorna|erro|refaz|ler|gravar|abrir|fechar|achou|naoAchou|iniciarTransacao|finalizarTransacao|desfazerTransacao|execSql|execSqlEx|proximo|primeiro|ultimo)\\b"
        },
        {
            "name": "keyword.operator.senior",
            "match": "(=|<>|<=|>=|<|>|\\+|\\-|\\*|/|\\+\\+|\\-\\-|(?i)\\b(e|ou|nao)\\b)"
        },
        {
            "name": "constant.numeric.senior",
            "match": "\\b\\d+(?:[\\.,]\\d+)?\\b"
        },
        {
            "name": "entity.name.function.senior",
            "match": "(?i)\\b([A-Z_][A-Z0-9_]*)(?=\\s*\\()"
        },
        {
            "name": "string.quoted.double.senior",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "match": "\\\\.",
                    "name": "constant.character.escape.senior"
                }
            ]
        }      
    ],
    "fileTypes": [
        "senior",
        "sen",
        "lsp"
    ],
    "uuid": "senior-lsp-syntax"
}
