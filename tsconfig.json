{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "moduleResolution": "node",
    "lib": [
      "es2018"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
